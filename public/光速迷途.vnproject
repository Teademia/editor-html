          "emotion_curve": [[0, 0.9], [0.7, 0.6], [1.0, 0.4]],
          "input_state": { "location": "先驱号核心舱 / 天狼星研究站", "variables": {} },
          "foreshadow_collect": ["陈默照片", "时光机来历", "顾北的秘密", "物理开关"],
