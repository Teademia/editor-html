{
  "__version": 1,
  "project": {
    "title": "潘多拉之潮",
    "story_bible": {
      "opening": "公元2037年，GenerationGene 公司与 CloseAI 公司联合重设计海洋微生物 SAR11，试图重构全球碳循环并制造高密度生物能源。泄漏发生后，SAR11 在十四天内覆盖南极冰架，引发不可逆的融化与全球海平面暴涨，暗红色海潮吞没世界。\n\n玩家扮演楚云天，灾变初期的海洋微生物与气候工程研究员。他最先意识到 SAR11 不只是污染，而是一个正在改写海洋生态、陆地生物和国家秩序的生命系统。为了阻止文明沉没，他必须从实验室走向权力中心，整合科研、军工、外交和民众动员，带领国家穿过潘多拉之潮。",
      "target_words": 200000,
      "world": {
        "setting": "近未来海洋灾变科幻。2037 年后，SAR11 变异体重塑全球海洋生态，南极融化、暗红潮汐、沿海城市沉没，旧世界的能源、粮食、交通和国家边界被迫重组。塔罗斯海原名太平洋，是灾厄七大洋之一，海中出现由变异生物群落组成的巨型复合生命体，如水蛭鲸、浮藻城、珊瑚神经网。",
        "rules": "1. SAR11 不是单一病原体，而是会与宿主生态共生、驱动突变的微生物网络。\n2. 被 SAR11 高浓度污染的海域会形成群体意志般的生态反馈，但它不等同于人类意义上的智慧。\n3. 国家仍存在，但沿海失守后权力重心转入内陆、地下城、海上平台和高原工业带。\n4. 科研突破必须依赖样本、算力、时间、政治信任和公众配合，任何一项不足都会导致防线崩溃。\n5. 玩家选择会改变科研路线、政权稳定度、民众信任、军事化程度和最终文明形态。",
        "tone": "宏大灾变、硬科幻、政治决策与个人牺牲并重。恐怖场面强调生态异化和生理压迫，国家线强调制度、资源和人心的重量。主角不是天选救世主，而是一步步被现实推上领导位置的人。"
      },
      "protagonist": {
        "name": "楚云天",
        "personality": ["理性", "冷静", "责任感强", "克制", "不愿服输"],
        "motivation": "证明 SAR11 灾变仍可被理解和控制，保护自己的国家与幸存者，让文明不被海潮吞没。",
        "flaw": "过度相信理性模型，早期低估政治阻力和民众恐惧，习惯把危机当作科研问题而不是社会问题。"
      },
      "variables": [
        { "name": "research", "initial": 4, "min": 0, "max": 10 },
        { "name": "authority", "initial": 1, "min": 0, "max": 10 },
        { "name": "public_trust", "initial": 3, "min": 0, "max": 10 },
        { "name": "military_control", "initial": 2, "min": 0, "max": 10 },
        { "name": "ecology_understanding", "initial": 2, "min": 0, "max": 10 },
        { "name": "humanity_cost", "initial": 0, "min": 0, "max": 10 }
      ],
      "endings": [
        {
          "title": "蓝色防线",
          "condition": "research >= 8 && public_trust >= 7 && humanity_cost <= 5",
          "description": "楚云天建立可持续的海陆防线，SAR11 被限制在可监控生态圈内。国家虽付出惨重代价，却保住了制度、人口和未来。"
        },
        {
          "title": "钢铁方舟",
          "condition": "authority >= 8 && military_control >= 8 && humanity_cost >= 6",
          "description": "国家以高度军事化方式幸存，海潮被挡在要塞之外，但自由与旧日生活被一并封存。楚云天赢得战争，也失去了最初想保护的东西。"
        },
        {
          "title": "与潮共生",
          "condition": "ecology_understanding >= 8 && research >= 6 && public_trust >= 5",
          "description": "楚云天发现 SAR11 可被引导而非彻底消灭，人类文明转向半海洋化共生路线，国家成为新生态秩序的设计者。"
        },
        {
          "title": "红潮亡国",
          "condition": "research < 5 || public_trust < 3",
          "description": "科研停滞或社会信任崩塌，谣言、迁徙和水源污染击穿国家防线。暗红色海潮越过最后一道高原堤坝。"
        },
        {
          "title": "潘多拉之王",
          "condition": "authority >= 9 && ecology_understanding >= 8 && humanity_cost >= 8",
          "description": "楚云天掌握了驱动 SAR11 群落的方法，成为灾后世界事实上的统治者。但人类是否仍在被拯救，已经无人敢问。"
        }
      ]
    },
    "structure": {
      "template": "save_the_cat",
      "branching_beat_id": "midpoint",
      "beats": [
