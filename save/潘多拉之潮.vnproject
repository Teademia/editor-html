    "blocks": [
      {
        "id": "block_1",
        "beat_id": "opening",
        "title": "水蛭鲸之口",
        "status": "skeleton_done",
        "word_target": 20000,
        "design": {
          "purpose": "以楚云天从水蛭鲸口中苏醒作为强钩子，展示塔罗斯海的生态异化，并转入灾前档案，建立 SAR11 与潘多拉之潮的基本设定。",
          "emotion_curve": [["窒息", 0.2], ["惊惧", 0.45], ["求生", 0.7], ["冷静回忆", 0.9]],
          "input_state": { "location": "塔罗斯海，水蛭鲸体内", "variables": { "research": 4, "authority": 1, "public_trust": 3 } },
          "foreshadow_collect": [],
          "foreshadow_plant": ["水蛭鲸并非捕食者，而是在执行某种生态清理行为", "SAR11 对陆生吸血生物的改造能力", "楚云天曾参与过 SAR11 风险评估"],
          "choice_points": [
            {
              "source": "author",
              "position_hint": "逃出水蛭鲸时",
              "reason": "建立玩家的第一组价值取向：保全样本还是保全自己",
              "options": [
                { "text": "割开防护服取出活体样本", "effect": "research += 1, humanity_cost += 1" },
                { "text": "立刻逃向光缝", "effect": "public_trust += 1" }
              ]
            }
          ],
          "outcomes": ["楚云天逃离水蛭鲸", "确认塔罗斯海生态已发生复合突变", "引出四海纪元档案与灾变源头"]
        },
        "skeleton": "1. 楚云天在黑暗、湿滑、粘稠的环境中苏醒，误以为自己身处洞穴。\n2. 他被水蛭咬伤，凭专业知识判断这些水蛭不是自然演化物种。\n3. 天地震动，水蛭鲸张口换气，灰色天空和塔罗斯海显露。\n4. 楚云天意识到自己身处由无数水蛭编织成的鲸鱼口腔。\n5. [选择点·作者] 保留活体样本或优先逃生。\n6. 他借助水蛭鲸张口的瞬间逃出，落入漂浮残骸。\n7. 残骸上的旧终端自动播放《四海纪元档案》。\n8. 档案揭示 2037 年 SAR11 泄漏、南极暗红生物膜和潘多拉之潮。\n9. 楚云天回忆自己曾是 SAR11 风险评估组成员，却被公司与上级压下报告。\n10. 远处海面再次隆起，更多复合生命体向沿海方向移动。",
        "output_state": { "location": "塔罗斯海漂浮残骸", "variables": { "research": 5 }, "open_foreshadows": ["水蛭鲸的生态清理行为", "被压下的风险评估报告"] }
      },
      {
