        "status": "skeleton_done",
        "word_target": 20000,
        "design": {
          "purpose": "回到灾变初期，楚云天试图向国家预警，但企业、部门和国际舆论都在压制真相。南极十四天崩解成为无法否认的催化事件。",
          "emotion_curve": [["怀疑", 0.2], ["焦急", 0.45], ["愤怒", 0.65], ["警报", 0.9]],
          "input_state": { "location": "2037 年，国家海洋生物安全中心", "variables": { "research": 4, "authority": 1, "public_trust": 3 } },
          "foreshadow_collect": ["被压下的风险评估报告"],
          "foreshadow_plant": ["CloseAI 超算系统依赖 SAR11 生物能源", "GenerationGene 内部有人主动掩盖泄漏", "首都地下应急工程蓝图"],
          "choice_points": [
            {
              "source": "author",
              "position_hint": "第一次内部听证会",
